{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/internal/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/internal/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/internal",
  "generateOptions": { "spec": false },
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": { "tsConfigPath": "libs/common/tsconfig.lib.json" }
    },
    "validator": {
      "type": "library",
      "root": "libs/validator",
      "entryFile": "index",
      "sourceRoot": "libs/validator/src",
      "compilerOptions": { "tsConfigPath": "libs/validator/tsconfig.lib.json" }
    },
    "internal": {
      "type": "application",
      "root": "apps/internal",
      "entryFile": "main",
      "sourceRoot": "apps/internal/src",
      "compilerOptions": {
        "tsConfigPath": "apps/internal/tsconfig.app.json"
      }
    }
  }
}
